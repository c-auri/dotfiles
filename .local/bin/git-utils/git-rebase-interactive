#!/bin/bash

# Interactively rebases commits back to a given depth or the merge-base with the default branch

source "$HOME/.local/bin/git-utils/git-lib"

if [[ -n $1 ]]
then
    base="HEAD~$1"
else
    base="$(git merge-base HEAD "$(get_default_branch)")"
fi

git rebase --interactive --autosquash "$base"
