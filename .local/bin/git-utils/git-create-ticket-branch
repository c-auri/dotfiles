#!/bin/bash

# Create a new branch following the VPPGERMAB ticket naming convention

prefix="feature"
if [[ "$1" == "-b" || "$1" == "--bugfix" ]]
then
  prefix="bugfix"
fi

while true
do
  read -rp "Ticket number: " number
  [[ "$number" =~ ^[0-9]+$ ]] && break
  echo "Must be numeric."
done

read -rp "Description (optional): " description

branch="${prefix}/VPPGERMAB-${number}"
if [[ -n "$description" ]]
then
  # Replace spaces with hyphens, preserve capitalization
  suffix="${description// /-}"
  branch="${branch}-${suffix}"
fi

git switch -c "$branch"
