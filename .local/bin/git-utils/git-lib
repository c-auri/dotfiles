#!/bin/bash

function get_remote
{
    # if the repo has more than one remote, this is inaccurate
    # I'll fix it if that ever happens to me ¯\_(ツ)_/¯
    git remote | head -1
}

function get_default_branch {
    local ref
    ref=$(git symbolic-ref --short "refs/remotes/$(get_remote)/HEAD")
    [[ "$1" == "upstream" ]] && echo $ref || echo ${ref##*/}
}
