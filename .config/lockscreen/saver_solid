#!/usr/bin/env python3

"""saver_solid: an xsecurelock saver module that paints its window a single
solid color, then idles until killed. Counterpart to the bundled saver_blank
(hardcoded to BlackPixel), but with a configurable color.

Reads:
  XSCREENSAVER_WINDOW   window ID to paint (set by xsecurelock)
  SAVER_SOLID_COLOR     X11 color name or "#rrggbb" (defaults to "black")

Talks to libX11 via ctypes so it depends only on the Python standard library
plus libX11.so.6, which is already present on any X session.
"""

import ctypes
import os
import signal
import sys


class XColor(ctypes.Structure):
    _fields_ = [
        ("pixel", ctypes.c_ulong),
        ("red", ctypes.c_ushort),
        ("green", ctypes.c_ushort),
        ("blue", ctypes.c_ushort),
        ("flags", ctypes.c_byte),
        ("pad", ctypes.c_byte),
    ]


def main() -> int:
    win_str = os.environ.get("XSCREENSAVER_WINDOW", "")
    if not win_str:
        print("saver_solid: XSCREENSAVER_WINDOW not set", file=sys.stderr)
        return 1
    window = int(win_str, 0)
    color_name = os.environ.get("SAVER_SOLID_COLOR", "black").encode()

    x = ctypes.CDLL("libX11.so.6")
    x.XOpenDisplay.argtypes = [ctypes.c_char_p]
    x.XOpenDisplay.restype = ctypes.c_void_p
    x.XDefaultScreen.argtypes = [ctypes.c_void_p]
    x.XDefaultScreen.restype = ctypes.c_int
    x.XDefaultColormap.argtypes = [ctypes.c_void_p, ctypes.c_int]
    x.XDefaultColormap.restype = ctypes.c_ulong
    x.XParseColor.argtypes = [
        ctypes.c_void_p, ctypes.c_ulong, ctypes.c_char_p, ctypes.POINTER(
            XColor),
    ]
    x.XParseColor.restype = ctypes.c_int
    x.XAllocColor.argtypes = [
        ctypes.c_void_p, ctypes.c_ulong, ctypes.POINTER(XColor),
    ]
    x.XAllocColor.restype = ctypes.c_int
    x.XSetWindowBackground.argtypes = [
        ctypes.c_void_p, ctypes.c_ulong, ctypes.c_ulong,
    ]
    x.XClearWindow.argtypes = [ctypes.c_void_p, ctypes.c_ulong]
    x.XFlush.argtypes = [ctypes.c_void_p]

    dpy = x.XOpenDisplay(None)
    if not dpy:
        print("saver_solid: cannot open display", file=sys.stderr)
        return 1
    cmap = x.XDefaultColormap(dpy, x.XDefaultScreen(dpy))
    xc = XColor()
    if not x.XParseColor(dpy, cmap, color_name, ctypes.byref(xc)):
        print(
            f"saver_solid: bad color: {color_name.decode()}", file=sys.stderr)
        return 1
    if not x.XAllocColor(dpy, cmap, ctypes.byref(xc)):
        print("saver_solid: cannot allocate color", file=sys.stderr)
        return 1
    x.XSetWindowBackground(dpy, window, xc.pixel)
    x.XClearWindow(dpy, window)
    x.XFlush(dpy)

    while True:
        signal.pause()


if __name__ == "__main__":
    sys.exit(main())
