configuration {
    modi:                "drun";
    show-icons:          true;
    icon-theme:          "Papirus";
    drun-display-format: "{name} [<span style='italic' size='small'>{generic}</span>]";
    display-drun:        "❯";
    disable-history:     false;
}

@import "~/.config/rofi/shared-style.rasi"

entry {
    placeholder-color: @selected;
}

element {
    spacing: 12px;
}

element-icon {
    size:             20px;
    background-color: transparent;
}
