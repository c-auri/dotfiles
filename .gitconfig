[core]
	editor = nvim
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[pull]
	ff = only
[status]
	showUntrackedFiles = all
[alias]
	co = checkout
	sw = switch
	cp = cherry-pick
	pf = push --force-with-lease
	unstage = restore --staged
	amend = commit --amend
	fixup = commit --fixup
	sm = !git-switch-to-main
	um = !git-update-main
	sf = !git-switch-fuzzy
	af = !git-add-fuzzy
	ri = !git-rebase-interactive
	rc = rebase --continue
	rom = !git-rebase-origin-main

[merge]
	conflictStyle = zdiff3

[include]
	path = ~/.config/git/local.ini

