[core]
	editor = nvim
[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
[pull]
	ff = only
[status]
	showUntrackedFiles = all
[alias]
	co = checkout
	sw = switch
	cp = cherry-pick
	unstage = restore --staged
	amend = commit --amend
	fixup = commit --fixup
	pf = push --force-with-lease
	graph = !git-graph
	root = !git-root
	sm = !git-switch-to-main
	um = !git-update-main
	sf = !git-switch-fuzzy
	af = !git-add-fuzzy
	ri = !git-rebase-interactive
	rc = rebase --continue
	rom = !git-rebase-origin-main

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true  # use n and N to move between diff sections
	dark = true      # or `light = true`, or omit for auto-detection

[merge]
	conflictStyle = zdiff3

[include]
	path = ~/.config/git/local.ini

